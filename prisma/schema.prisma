generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS - Existing
// ============================================
enum UserRole {
  CUSTOMER
  MERCHANT
  FAMILY_PRODUCER
  DRIVER
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  KCB_BANK
  JEEB_WALLET
}

enum ProductStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================
// NEW ENUMS - Phase 1 (For New Tables Only)
// ============================================

enum WalletTxType {
  CREDIT
  DEBIT
  HOLD
  RELEASE
  REFUND
  COMMISSION
}

// ============================================
// EXISTING MODELS - With Safe Additions
// ============================================

model User {
  id           String   @id @default(uuid())
  phone        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole
  fullName     String   @map("full_name")
  email        String?
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  fcmToken     String?  @map("fcm_token")

  // Phase 1 Safe Additions: Soft Delete & Verification
  deletedAt     DateTime? @map("deleted_at")
  emailVerified Boolean   @default(false) @map("email_verified")
  phoneVerified Boolean   @default(false) @map("phone_verified")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  customer      Customer?
  merchant      Merchant?
  driver        Driver?
  admin         Admin?
  notifications Notification[]

  // Phase 1 Safe Additions: New Relations
  addresses    Address[]
  wallet       Wallet?
  bankAccounts BankAccount[]

  @@index([deletedAt])
  @@index([phone])
  @@index([role])
  @@map("users")
}

model Customer {
  userId    String  @id @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  address   String
  lat       Float?
  lng       Float?
  building  String?
  floor     String?
  apartment String?

  // Phase 1 Safe Additions
  deletedAt DateTime? @map("deleted_at")

  orders    Order[]
  wishlists Wishlist[] // ✅ مرحلة 2
  carts     Cart[]     // ✅ مرحلة 4

  @@index([deletedAt])
  @@map("customers")
}

model Merchant {
  userId String @id @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String // "MERCHANT" or "FAMILY_PRODUCER"
  storeName   String  @map("store_name")
  description String?

  idImageUrl      String? @map("id_image_url")
  licenseNumber   String? @map("license_number")
  licenseImageUrl String? @map("license_image_url")

  address String
  lat     Float
  lng     Float

  // SAFE: Keeping these fields for backward compatibility
  bankName      String  @map("bank_name")
  accountName   String  @map("account_name")
  accountNumber String? @map("account_number")



  commissionRate Float     @default(0.05) @map("commission_rate")
  isApproved     Boolean   @default(false) @map("is_approved")
  approvedAt     DateTime? @map("approved_at")
  approvedBy     String?   @map("approved_by")

  // Phase 1 Safe Additions
  deletedAt DateTime? @map("deleted_at")

  products Product[]
  orders   Order[]

  @@index([deletedAt])
  @@index([isApproved])
  @@map("merchants")
}

model Driver {
  userId String @id @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  vehicleType     String  @map("vehicle_type")
  vehicleNumber   String? @map("vehicle_number")
  vehicleImageUrl String? @map("vehicle_image_url")

  idImageUrl      String? @map("id_image_url")
  licenseImageUrl String? @map("license_image_url")

  // SAFE: Keeping these fields for backward compatibility
  bankName      String  @map("bank_name")
  accountName   String  @map("account_name")
  accountNumber String? @map("account_number")



  isApproved     Boolean   @default(false) @map("is_approved")
  isAvailable    Boolean   @default(false) @map("is_available")
  currentLat     Float?    @map("current_lat")
  currentLng     Float?    @map("current_lng")
  lastLocationAt DateTime? @map("last_location_at")

  // Phase 1 Safe Additions
  deletedAt DateTime? @map("deleted_at")

  orders      Order[]
  withdrawals Withdrawal[]

  @@index([deletedAt])
  @@index([isAvailable])
  @@index([currentLat, currentLng])
  @@map("drivers")
}

model Product {
  id         String   @id @default(uuid())
  merchantId String   @map("merchant_id")
  merchant   Merchant @relation(fields: [merchantId], references: [userId], onDelete: Cascade)

  name        String
  nameEn      String?       @map("name_en")
  description String?
  price       Decimal       @db.Decimal(10, 2)
  imageUrl    String?       @map("image_url")
  category    String
  unit        String        @default("قطعة")
  isAvailable Boolean       @default(true) @map("is_available")
  stock       Int           @default(0)
  discount    Int?          // نسبة الخصم %
  status      ProductStatus @default(PENDING)

  // Phase 1 Safe Additions
  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orderItems OrderItem[]
  wishlists  Wishlist[]  // ✅ مرحلة 2
  cartItems  CartItem[]  // ✅ مرحلة 4

  @@index([deletedAt])
  @@index([merchantId])
  @@index([category])
  @@index([status])
  @@index([isAvailable, deletedAt])
  @@map("products")
}

model Order {
  id String @id @default(uuid())

  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [userId])

  merchantId String   @map("merchant_id")
  merchant   Merchant @relation(fields: [merchantId], references: [userId])

  driverId String? @map("driver_id")
  driver   Driver? @relation(fields: [driverId], references: [userId])

  // Phase 1 Safe Additions: Address Link
  addressId String? @map("address_id")

  assignedDriverId     String?   @map("assigned_driver_id")
  assignmentExpiresAt  DateTime? @map("assignment_expires_at")
  rejectedDriverIds    String[]  @default([]) @map("rejected_driver_ids")

  status OrderStatus @default(PENDING)
  items  OrderItem[]

  subtotal    Decimal @db.Decimal(10, 2)
  deliveryFee Decimal @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  platformFee Decimal @map("platform_fee") @db.Decimal(10, 2)
  totalAmount Decimal @map("total_amount") @db.Decimal(10, 2)

  paymentMethod PaymentMethod @map("payment_method")
  isPaid        Boolean       @default(false) @map("is_paid")
  paidAt        DateTime?     @map("paid_at")

  deliveryAddress String @map("delivery_address")
  deliveryLat     Float  @map("delivery_lat")
  deliveryLng     Float  @map("delivery_lng")

  acceptedAt   DateTime? @map("accepted_at")
  preparedAt   DateTime? @map("prepared_at")
  pickedUpAt   DateTime? @map("picked_up_at")
  deliveredAt  DateTime? @map("delivered_at")
  cancelledAt  DateTime? @map("cancelled_at")
  cancelReason String?   @map("cancel_reason")

  // Phase 1 Safe Additions: Proof of Delivery
  proofImageUrl     String?   @map("proof_image_url")
  deliverySignature String?   @map("delivery_signature")
  deliveryOtp       String?   @map("delivery_otp")

  // Phase 1 Safe Additions
  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payment Payment?
  ratings Rating[]

  // Phase 1 Safe Additions
  statusHistory OrderStatusHistory[]
  Address       Address?             @relation(fields: [addressId], references: [id])

  @@index([deletedAt])
  @@index([customerId])
  @@index([merchantId])
  @@index([driverId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])

  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Payment {
  id      String @id @default(uuid())
  orderId String @unique @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id])

  totalAmount Decimal @map("total_amount") @db.Decimal(10, 2)
  platformFee Decimal @map("platform_fee") @db.Decimal(10, 2)
  driverFee   Decimal @map("driver_fee") @db.Decimal(10, 2)
  merchantNet Decimal @map("merchant_net") @db.Decimal(10, 2)

  // SAFE: Keeping as String
  status String // "pending", "completed", "failed"

  // Phase 1 Safe Additions
  transactionId String?   @map("transaction_id")
  processedAt   DateTime? @map("processed_at")
  failureReason String?   @map("failure_reason")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

model Withdrawal {
  id       String @id @default(uuid())
  driverId String @map("driver_id")
  driver   Driver @relation(fields: [driverId], references: [userId])

  amount Decimal @db.Decimal(10, 2)

  // SAFE: Keeping as String
  status String // "pending", "approved", "rejected", "completed"

  requestedAt DateTime  @default(now()) @map("requested_at")
  processedAt DateTime? @map("processed_at")
  processedBy String?   @map("processed_by")
  notes       String?

  // Phase 1 Safe Additions
  rejectionReason     String?      @map("rejection_reason")
  walletTransactionId String?      @map("wallet_transaction_id")
  bankAccountId       String?      @map("bank_account_id")
  idempotencyKey      String?      @unique @map("idempotency_key")
  BankAccount         BankAccount? @relation(fields: [bankAccountId], references: [id])

  @@index([driverId])
  @@index([status])
  @@index([requestedAt])
  @@index([idempotencyKey])
  @@map("withdrawals")
}

model Rating {
  id      String @id @default(uuid())
  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id])

  fromUserId String @map("from_user_id")
  toUserId   String @map("to_user_id")

  // SAFE: Keeping as String
  role String // "customer_to_driver", "customer_to_merchant", "driver_to_customer"

  rating    Int // 1-5
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([orderId, fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
  @@map("ratings")
}

model Notification {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  title String
  body  String
  type  String
  data  Json?

  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Admin {
  userId      String @id @map("user_id")
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions Json

  @@map("admins")
}

// ============================================
// NEW MODELS - Phase 1 Enterprise
// ============================================

model BankAccount {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountType String @map("account_type") // MERCHANT, DRIVER, ADMIN
  bankName    String

  // Encrypted fields (managed by backend encryption service)
  accountNumberEncrypted String  @map("account_number_encrypted")
  accountNameEncrypted   String  @map("account_name_encrypted")
  ibanEncrypted          String? @map("iban_encrypted")

  isDefault  Boolean @default(false) @map("is_default")
  isVerified Boolean @default(false) @map("is_verified")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  withdrawalsWithBank Withdrawal[]

  @@unique([userId, isDefault])
  @@index([userId])
  @@index([accountType])
  @@map("bank_accounts")
}

model Wallet {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  balance     Decimal @default(0) @db.Decimal(12, 2)
  holdBalance Decimal @default(0) @map("hold_balance") @db.Decimal(12, 2)
  currency    String  @default("YER")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transactions WalletTransaction[]

  @@index([userId])
  @@map("wallets")
}

model WalletTransaction {
  id       String @id @default(uuid())
  walletId String @map("wallet_id")
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  transactionType WalletTxType @map("transaction_type")
  amount          Decimal      @db.Decimal(12, 2)

  balanceBefore Decimal @map("balance_before") @db.Decimal(12, 2)
  balanceAfter  Decimal @map("balance_after") @db.Decimal(12, 2)

  referenceType String? @map("reference_type") // ORDER, WITHDRAWAL, TOPUP
  referenceId   String? @map("reference_id")

  description String?
  metadata    Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([walletId])
  @@index([walletId, createdAt])
  @@index([referenceType, referenceId])
  @@map("wallet_transactions")
}

model Address {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  label   String? // "Home", "Work"
  address String
  lat     Decimal? @db.Decimal(10, 8)
  lng     Decimal? @db.Decimal(11, 8)

  building               String?
  floor                  String?
  apartment              String?
  additionalInstructions String? @map("additional_instructions")

  isDefault Boolean @default(false) @map("is_default")
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  orders Order[]

  @@index([userId])
  @@index([isDefault])
  @@index([isActive])
  @@map("addresses")
}

model AuditLog {
  id String @id @default(uuid())

  tableName String @map("table_name")
  recordId  String @map("record_id")
  action    String // INSERT, UPDATE, DELETE

  oldData Json? @map("old_data")
  newData Json? @map("new_data")

  performedBy String?  @map("performed_by")
  performedAt DateTime @default(now()) @map("performed_at")

  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  @@index([tableName, recordId])
  @@index([performedAt])
  @@index([performedBy])
  @@map("audit_logs")
}

model OrderStatusHistory {
  id      String @id @default(uuid())
  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  previousStatus OrderStatus? @map("previous_status")
  newStatus      OrderStatus  @map("new_status")

  changedBy    String? @map("changed_by")
  changeReason String? @map("change_reason")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@index([createdAt])
  @@map("order_status_history")
}

// ============================================
// PHASE 2 — Wishlist
// ============================================

model Wishlist {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  productId  String   @map("product_id")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [userId], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@index([customerId])
  @@index([productId])
  @@map("wishlists")
}

// ============================================
// PHASE 3 — Promo Codes
// ============================================

model PromoCode {
  id               String    @id @default(uuid())
  code             String    @unique
  type             String    // "PERCENTAGE" | "FIXED"
  value            Float     // نسبة مئوية أو قيمة ثابتة
  minOrderAmount   Float     @default(0) @map("min_order_amount")
  maxDiscount      Float?    @map("max_discount")
  usageLimit       Int?      @map("usage_limit")
  usagePerCustomer Int       @default(1) @map("usage_per_customer")
  usedCount        Int       @default(0) @map("used_count")
  expiresAt        DateTime? @map("expires_at")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")

  usages PromoUsage[]

  @@index([code])
  @@index([isActive])
  @@map("promo_codes")
}

model PromoUsage {
  id          String   @id @default(uuid())
  promoCodeId String   @map("promo_code_id")
  customerId  String   @map("customer_id")
  orderId     String?  @map("order_id")
  usedAt      DateTime @default(now()) @map("used_at")

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, customerId, orderId])
  @@index([promoCodeId])
  @@index([customerId])
  @@map("promo_usages")
}

// ============================================
// PHASE 4 — Wishlist & Cart
// ============================================

model Wishlist {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [userId], onDelete: Cascade)
  productId  String   @map("product_id")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([customerId, productId])
  @@index([customerId])
  @@map("wishlists")
}

model Cart {
  id         String     @id @default(uuid())
  customerId String     @map("customer_id")
  customer   Customer   @relation(fields: [customerId], references: [userId], onDelete: Cascade)
  status     String     @default("ACTIVE") // ACTIVE | CHECKED_OUT
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  items      CartItem[]

  @@index([customerId, status])
  @@map("carts")
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String  @map("cart_id")
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
  price     Decimal @db.Decimal(10, 2)

  @@unique([cartId, productId])
  @@index([cartId])
  @@map("cart_items")
}
